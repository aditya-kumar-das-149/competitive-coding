class Solution {
public:
    int trap(vector<int>& h){
    int l=0,r=h.size()-1,ml=0,mr=0,ans=0;
    while(l<r){
        if(h[l]<h[r]){
            ml=max(ml,h[l]);
            ans+=ml-h[l++];
        }else{
            mr=max(mr,h[r]);
            ans+=mr-h[r--];
        }
    }
    return ans;
}    
};
